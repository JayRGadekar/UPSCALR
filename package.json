{
  "name": "vllama",
  "version": "0.1.0",
  "description": "Local video upscaling desktop application",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:electron": "env -u ELECTRON_RUN_AS_NODE concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "npm run build --prefix frontend && npm run build --prefix backend",
    "build:electron": "npm run build --prefix frontend && electron-builder",
    "dist": "npm run build:electron",
    "start": "npm run start --prefix backend",
    "pack": "electron-builder --dir",
    "preelectron-pack": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "nodemon": "^3.0.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.vllama.app",
    "productName": "VLLAMA",
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 110,
          "y": 150,
          "type": "file"
        },
        {
          "x": 240,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "electron/**/*",
      "frontend/dist",
      "backend/src",
      "backend/package.json",
      "node_modules"
    ]
  }
}
